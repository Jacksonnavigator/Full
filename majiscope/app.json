{
  "expo": {
    "name": "Majiscope Engineer App",
    "slug": "hydranet-engineer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#eef9ff"
      },
      "package": "com.hydratech.majiscopeengineer",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#eef9ff"
        }
      ],
      "expo-location",
      "expo-image-picker",
      "expo-notifications",
      "expo-video"
    ],
    "owner": "jacksonnavigator7",
    "extra": {
      "eas": {
        "projectId": "abd3bda0-c120-405d-8321-9dcf2e037dd9"
      }
    }
  }
}
