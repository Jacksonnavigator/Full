/**
 * HydraNet Firebase Firestore Security Rules
 * Enforces role-based access control and data isolation
 * 
 * Apply these rules in Firebase Console > Firestore > Rules
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAdmin() {
      return request.auth.token.role == 'Administrator';
    }
    
    function isUtilityManager() {
      return request.auth.token.role == 'UtilityManager';
    }
    
    function isDMAManager() {
      return request.auth.token.role == 'DMAManager';
    }
    
    function isEngineerOrLeader() {
      return request.auth.token.role in ['Engineer', 'TeamLeader'];
    }
    
    function getUserUtilityId() {
      return request.auth.token.utilityId;
    }
    
    function getUserDMAId() {
      return request.auth.token.dmaId;
    }
    
    function getUserTeamId() {
      return request.auth.token.teamId;
    }
    
    // ============ UTILITIES ============
    match /utilities/{utilityId} {
      allow read: if isAdmin() || (isUtilityManager() && getUserUtilityId() == utilityId);
      allow write: if isAdmin();
      
      match /{document=**} {
        allow read: if isAdmin() || (isUtilityManager() && getUserUtilityId() == utilityId);
        allow write: if isAdmin();
      }
    }
    
    // ============ DMAs ============
    match /dmas/{dmaId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId());
      allow write: if isAdmin() || isUtilityManager();
      
      match /{document=**} {
        allow read: if isAdmin() || 
                     (isUtilityManager() && get(/databases/$(database)/documents/dmas/$(dmaId)).data.utilityId == getUserUtilityId()) ||
                     (isDMAManager() && get(/databases/$(database)/documents/dmas/$(dmaId)).data.dmaId == getUserDMAId());
        allow write: if isDMAManager();
      }
    }
    
    // ============ BRANCHES ============
    match /branches/{branchId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId()) ||
                   isEngineerOrLeader();
      allow write: if isDMAManager() && resource.data.dmaId == getUserDMAId();
    }
    
    // ============ USERS ============
    match /users/{userId} {
      allow read: if request.auth.uid == userId ||
                   isAdmin() ||
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId());
      allow write: if request.auth.uid == userId ||
                    isAdmin() ||
                    (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                    (isDMAManager() && resource.data.dmaId == getUserDMAId());
    }
    
    // ============ TEAMS ============
    match /teams/{teamId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId()) ||
                   (isEngineerOrLeader() && resource.data.teamId == getUserTeamId());
      allow write: if isDMAManager() && resource.data.dmaId == getUserDMAId();
    }
    
    // ============ REPORTS ============
    match /reports/{reportId} {
      allow create: if true; // Public can create reports
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId()) ||
                   (isEngineerOrLeader() && resource.data.assignedTeamId == getUserTeamId());
      allow update: if isAdmin() || 
                     (isDMAManager() && resource.data.dmaId == getUserDMAId()) ||
                     (isEngineerOrLeader() && resource.data.assignedTeamId == getUserTeamId());
      
      match /activities/{activity} {
        allow read: if isAdmin() || 
                     (isUtilityManager() && get(/databases/$(database)/documents/reports/$(reportId)).data.utilityId == getUserUtilityId()) ||
                     (isDMAManager() && get(/databases/$(database)/documents/reports/$(reportId)).data.dmaId == getUserDMAId());
        allow write: if isAdmin() || isDMAManager();
      }
    }
    
    // ============ SUBMISSIONS ============
    match /submissions/{submissionId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && 
                    getUserUtilityId() == get(/databases/$(database)/documents/reports/$(resource.data.reportId)).data.utilityId) ||
                   (isDMAManager() && 
                    getUserDMAId() == get(/databases/$(database)/documents/reports/$(resource.data.reportId)).data.dmaId) ||
                   (isEngineerOrLeader() && resource.data.teamId == getUserTeamId());
      allow create: if isEngineerOrLeader() && resource.data.teamId == getUserTeamId();
      allow update: if isDMAManager() || 
                     (isEngineerOrLeader() && resource.data.teamId == getUserTeamId());
    }
    
    // ============ AUDIT LOGS ============
    match /auditLogs/{logId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId());
      allow write: if true; // Backend only
    }
    
    // ============ PERFORMANCE METRICS ============
    match /teamMetrics/{metricId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId()) ||
                   (isDMAManager() && resource.data.dmaId == getUserDMAId());
      allow write: if isAdmin();
    }
    
    match /dmaMetrics/{metricId} {
      allow read: if isAdmin() || 
                   (isUtilityManager() && resource.data.utilityId == getUserUtilityId());
      allow write: if isAdmin();
    }
    
    // ============ NOTIFICATIONS ============
    match /notifications/{notificationId} {
      allow read: if request.auth.uid in get(/databases/$(database)/documents/notifications/$(notificationId)).data.recipientIds;
      allow write: if true; // Backend only
    }
  }
}

// ============ STORAGE SECURITY RULES ============
service firebase.storage {
  match /b/{bucket}/o {
    // Reports images - accessible by relevant users
    match /reports/{reportId}/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Backend validation will ensure appropriate access
    }
    
    // Submission images (before/after photos)
    match /submissions/{submissionId}/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Backend validation will ensure appropriate access
    }
    
    // User profile photos
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }
  }
}
