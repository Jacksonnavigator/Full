ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=https://your-frontend.onrender.com
PUBLIC_BACKEND_URL=https://your-backend.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com
HOST=0.0.0.0
PORT=8000
INVITE_TOKEN_EXPIRY_HOURS=72
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=2

# Optional one-time historical DUWASA import on deploy
LEGACY_DUWASA_IMPORT_ON_STARTUP=false
# Optional override. Leave blank to use the CSV committed inside the backend folder.
LEGACY_DUWASA_IMPORT_CSV_PATH=
LEGACY_DUWASA_IMPORT_STRICT=false
# LEGACY_DUWASA_IMPORT_LIMIT=50


# Recommended Resend setup
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=invites@mail.majiscope.site
RESEND_FROM_NAME=Majiscope

# Optional SMTP fallback (Render Free blocks SMTP ports, so use this only where SMTP is allowed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your_16_character_app_password
SMTP_FROM_EMAIL=yourgmail@gmail.com
SMTP_FROM_NAME=Majiscope
SMTP_USE_TLS=true
